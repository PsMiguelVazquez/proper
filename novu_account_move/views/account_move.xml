<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="account_move_view_list" model="ir.ui.view">
            <field name="name">account.out.invoice.list</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree" />
            <field name="mode">extension</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="remision_name" />
                </xpath>
                <xpath expr="//field[@name='invoice_partner_display_name']" position="after">
                    <field name="x_studio_mkp_1" />
                    <field name="invoice_origin" />
                    <field name="x_studio_n_orden_de_compra" />
                </xpath>
            </field>
        </record>
    </data>
</odoo>