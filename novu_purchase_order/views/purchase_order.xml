<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="res_purchase_view_form" model="ir.ui.view">
            <field name="name">purchase.order.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form" />
            <field name="mode">extension</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/list//field[@name='name']" position="attributes">
                    <attribute name="invisible">False</attribute>
                    <attribute name="optional">show</attribute>
                    <attribute name="column_invisible">False</attribute>
                </xpath>
                <xpath expr="//field[@name='user_id']" position="before">
                    <field name="x_studio_many2one_field_UTgPw" />
                </xpath>
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="x_studio_nmero_de_factura" />
                </xpath>
                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="string">Agente de Compras</attribute>
                </xpath>
                <xpath expr="//notebook[1]/page[@name='purchase_delivery_invoice']" position="after">
                        <page string="SO" name="page_so">
                          <group name="group_so">
                            <field name="sale_ids" nolabel="1">
                              <list string="Sales Orders" multi_edit="1" sample="1">
                                <field name="message_needaction" optional="hide" invisible="1"/>
                                <field name="x_studio_n_orden_de_compra" optional="hide" invisible="1"/>
                                <!-- <field name="name" string="Number" readonly="1" decoration-bf="1"/>-->
                                <field name="date_order" string="Order Date" widget="date" readonly="state not in ['draft','sent']" optional="hide" invisible="1"/>
                                <field name="commitment_date" optional="hide"/>
                                <field name="expected_date" optional="hide"/>
                                <field name="partner_id" readonly="1" optional="hide" invisible="1"/>
                                <field name="x_studio_cliente_de_marketplace" optional="hide" invisible="1"/>
                                <field name="display_name"/>
                                <field name="user_id" optional="show" widget="many2one_avatar_user"/>
                                <field name="team_id" optional="hide"/>
                                <field name="company_id" groups="base.group_multi_company" optional="hide" readonly="1"/>
                                <field name="amount_untaxed" sum="Total Tax Excluded" widget="monetary" optional="hide"/>
                                <field name="amount_tax" sum="Tax Total" widget="monetary" optional="hide"/>
                                <field name="amount_total" sum="Total Tax Included" widget="monetary" decoration-bf="1" optional="hide" attrs="{}" invisible="1"/>
                                <field name="currency_id" optional="hide" invisible="1"/>
                                <field name="invoice_status" decoration-success="invoice_status == 'invoiced'" decoration-info="invoice_status == 'to invoice'" decoration-warning="invoice_status == 'upselling'" widget="badge" optional="show"/>
                                <field name="tag_ids" optional="hide" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                <field name="state" optional="hide" invisible="1"/>
                              </list>
                            </field>
                          </group>
                        </page>
                </xpath>
                
            </field>
        </record>
    </data>
</odoo>