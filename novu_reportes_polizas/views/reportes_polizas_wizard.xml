<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="reportes_polizas_wizard_form" model="ir.ui.view">
        <field name="name">reportes.polizas.wizard.form</field>
        <field name="model">reportes.polizas.wizard</field>
        <field name="arch" type="xml">
            <form string="Poliza de diario">
                <sheet>
                    <group>
                        <group>
                            <field name="descripcion" />
                             <field name="date_start" string="Fecha Inicial" invisible="0" />
                        </group>                        
                    </group>
                </sheet>
                <footer>
                    <button type="object" name="action_report" string="Crear Reporte Excel" class="oe_highlight" icon="fa-cogs" />
                    
                </footer>                
            </form>
        </field>
    </record>
    
    <record id="action_reportes_polizas_wizard_form" model="ir.actions.act_window">
        <field name="name">Reportes de polizas</field>
        <field name="res_model">reportes.polizas.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    
    <menuitem id="menu_polizas" name="Polizas" parent="account.menu_finance_reports"/>
    <menuitem id="menu_wizreportespolizas" name="Poliza de diario" parent="menu_polizas" action="action_reportes_polizas_wizard_form" sequence="6"/>
</odoo>