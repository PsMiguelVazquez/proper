<odoo>
    <data>
        <!-- Accion automatizada bloquea los cambios de etapa en el CRM-->
        <record id="action_bloquea_cambio_etapa_evaluacion_crm" model="ir.actions.server">
            <field name="name">Novu: CRM - bloquea cambio de etapa Evaluacion</field>
            <field name="model_id" ref="crm.model_crm_lead"/>  
            <field name="state">code</field>
            <field name="code"> 
record.validar_informacion_evaluacion()
            </field>
            <field name="usage">base_automation</field>
            <!--<field name="base_automation_id" ref="update_production"/>-->
        </record>
        
        <record id="bloquea_cambio_etapa_evaluacion_crm" model="base.automation">
            <field name="name">Novu: CRM - bloquea cambio de etapa Evaluacion por falta de información</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="trigger">on_stage_set</field>
            <field name="filter_domain">[('stage_id.name', '=', 'Evaluación')]</field>
            <field name="active" eval="True"/>
            <field name="action_server_ids" eval="[(4, ref('action_bloquea_cambio_etapa_evaluacion_crm'))]"/>
        </record>
    </data>
</odoo>